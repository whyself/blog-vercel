---
interface Props {
  selector?: string;
  offsetRatio?: number;
  behavior?: 'auto' | 'smooth';
  delayMs?: number;
}

const {
  selector = '[data-content-start]',
  offsetRatio = 0.22,
  behavior = 'smooth',
  delayMs = 120,
} = Astro.props as Props;

const script = `(() => {
  const contentStart = document.querySelector(${JSON.stringify(selector)});
  if (!contentStart) return;

  const run = () => {
    if (window.location.hash) return;
    const navigationType = performance.getEntriesByType("navigation")?.[0]?.type;
    if (navigationType === "back_forward") return;

    const contentTop = contentStart.getBoundingClientRect().top + window.scrollY;
    const targetTop = Math.max(0, Math.round(contentTop - window.innerHeight * ${offsetRatio}));
    const prefersReducedMotion = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const resolvedBehavior = prefersReducedMotion ? "auto" : ${JSON.stringify(behavior)};
    window.scrollTo({ top: targetTop, behavior: resolvedBehavior });
  };

  if ("scrollRestoration" in history) {
    history.scrollRestoration = "manual";
  }

  window.addEventListener("load", () => {
    window.setTimeout(() => {
      window.requestAnimationFrame(run);
    }, ${delayMs});
  }, { once: true });
})();`;
---

<script is:inline set:html={script}></script>
