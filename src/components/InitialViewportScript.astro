---
interface Props {
  selector?: string;
  offsetRatio?: number;
  behavior?: 'auto' | 'smooth';
  delayMs?: number;
}

const {
  selector = '[data-content-start]',
  offsetRatio = 0.22,
  behavior = 'smooth',
  delayMs = 120,
} = Astro.props as Props;

const script = `(() => {
  const contentStart = document.querySelector(${JSON.stringify(selector)});
  if (!contentStart) return;
  let hasScrolled = false;

  const run = () => {
    if (hasScrolled) return;

    const hash = window.location.hash ? decodeURIComponent(window.location.hash.slice(1)) : "";
    if (hash) {
      const hashTarget = document.getElementById(hash);
      if (hashTarget) {
        hasScrolled = true;
        hashTarget.scrollIntoView({ block: "start", behavior: "auto" });
        return;
      }
    }

    const contentTop = contentStart.getBoundingClientRect().top + window.scrollY;
    const targetTop = Math.max(0, Math.round(contentTop - window.innerHeight * ${offsetRatio}));
    if (Math.abs(window.scrollY - targetTop) <= 2) {
      hasScrolled = true;
      return;
    }
    const prefersReducedMotion = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const resolvedBehavior = prefersReducedMotion ? "auto" : ${JSON.stringify(behavior)};
    hasScrolled = true;
    window.scrollTo({ top: targetTop, behavior: resolvedBehavior });
  };

  const scheduleRun = (delay) => {
    window.setTimeout(() => {
      window.requestAnimationFrame(run);
    }, delay);
  };

  if ("scrollRestoration" in history) {
    history.scrollRestoration = "manual";
  }

  window.addEventListener("load", () => {
    scheduleRun(${delayMs});
    scheduleRun(${delayMs} + 260);
  }, { once: true });

  window.addEventListener("pageshow", (event) => {
    const delay = event.persisted ? 0 : ${delayMs};
    scheduleRun(delay);
    scheduleRun(delay + 260);
  });

  if (document.readyState === "complete") {
    scheduleRun(0);
    scheduleRun(260);
  }
})();`;
---

<script is:inline set:html={script}></script>
