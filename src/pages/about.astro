---
import { getCollection, render } from 'astro:content';
import ContentInfoPageLayout from '../layouts/ContentInfoPageLayout.astro';
import { buildSearchItems, getPublishedPosts } from '../utils/posts';

const base = import.meta.env.BASE_URL;
const posts = await getPublishedPosts();
const searchPosts = buildSearchItems(posts, base);
const pageEntry = (await getCollection('pages', ({ data }) => !data.draft)).find((entry) => entry.slug === 'about');
if (!pageEntry) throw new Error('Missing content file: src/content/pages/about.md');
const { Content } = await render(pageEntry);

const siteOrigin = Astro.site?.toString() ?? 'http://127.0.0.1:4321';
const seoTitle = 'About | whyself';
const seoDescription = pageEntry.data.subtitle ?? 'About whyself, personal background and writing focus.';
const canonicalUrl = new URL(`${base}about/`, siteOrigin).toString();
const ogImageUrl = new URL(`${base}images/profile-avatar.jpg`, siteOrigin).toString();
---

<ContentInfoPageLayout
  base={base}
  searchItems={searchPosts}
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  canonicalUrl={canonicalUrl}
  ogImageUrl={ogImageUrl}
  heroTitle="About"
  activeNav="about"
  sectionTitle="Who am I?"
  subtitle={pageEntry.data.subtitle}
>
  <Content />
</ContentInfoPageLayout>

