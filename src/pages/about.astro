---
import ContentInfoPageLayout from '../layouts/ContentInfoPageLayout.astro';
import { buildContentPageData } from '../utils/content-pages';

const base = import.meta.env.BASE_URL;
const siteOrigin = Astro.site?.toString() ?? 'http://127.0.0.1:4321';
const pageData = await buildContentPageData({
  base,
  siteOrigin,
  config: {
    slug: 'about',
    seoTitle: 'About | whyself',
    fallbackDescription: 'About whyself, personal background and writing focus.',
  },
});
const Content = pageData.Content;
---

<ContentInfoPageLayout
  base={base}
  searchItems={pageData.searchItems}
  seoTitle={pageData.seoTitle}
  seoDescription={pageData.seoDescription}
  canonicalUrl={pageData.canonicalUrl}
  ogImageUrl={pageData.ogImageUrl}
  heroTitle="About"
  activeNav="about"
  sectionTitle="Who am I?"
  subtitle={pageData.subtitle}
>
  <Content />
</ContentInfoPageLayout>
