---
import ArchivePageDocument from '../../components/ArchivePageDocument.astro';
import { ARCHIVE_PAGE_SIZE, getArchivePostsByRoute, getArchiveSeo, getTotalPages, paginatePosts } from '../../utils/archive';
import { buildSearchItems } from '../../utils/posts';

const base = import.meta.env.BASE_URL;
const { allPosts, routePosts } = await getArchivePostsByRoute('articles');
const posts = paginatePosts(routePosts, 1, ARCHIVE_PAGE_SIZE);
const totalPages = getTotalPages(routePosts, ARCHIVE_PAGE_SIZE);
const currentPage = 1;
const searchPosts = buildSearchItems(allPosts, base);
const siteOrigin = Astro.site?.toString() ?? 'http://127.0.0.1:4321';
const { seoTitle, seoDescription, canonicalUrl, ogImageUrl } = getArchiveSeo('articles', currentPage, base, siteOrigin);
---
<ArchivePageDocument
  base={base}
  posts={posts}
  searchItems={searchPosts}
  currentPage={currentPage}
  totalPages={totalPages}
  majorRoute="articles"
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  canonicalUrl={canonicalUrl}
  ogImageUrl={ogImageUrl}
/>
