---
import ArchivePageDocument from '../components/ArchivePageDocument.astro';
import { ARCHIVE_PAGE_SIZE, buildArchiveSearchItems, getArchivePostsByRoute, getArchiveSeo, getTotalPages, paginatePosts } from '../utils/archive';

const base = import.meta.env.BASE_URL;
const { allPosts, routePosts } = await getArchivePostsByRoute('all');
const posts = paginatePosts(routePosts, 1, ARCHIVE_PAGE_SIZE);
const totalPages = getTotalPages(routePosts, ARCHIVE_PAGE_SIZE);
const currentPage = 1;
const searchPosts = buildArchiveSearchItems(allPosts, base);
const siteOrigin = Astro.site?.toString() ?? 'http://127.0.0.1:4321';
const { seoTitle, seoDescription, canonicalUrl, ogImageUrl } = getArchiveSeo('all', currentPage, base, siteOrigin);
---
<ArchivePageDocument
  base={base}
  posts={posts}
  searchItems={searchPosts}
  currentPage={currentPage}
  totalPages={totalPages}
  majorRoute="all"
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  canonicalUrl={canonicalUrl}
  ogImageUrl={ogImageUrl}
/>
