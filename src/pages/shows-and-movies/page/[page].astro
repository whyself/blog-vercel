---
import ArchivePageDocument from '../../../components/ArchivePageDocument.astro';
import { ARCHIVE_PAGE_SIZE, buildArchiveSearchItems, buildArchiveStaticPaths, getArchivePostsByRoute, getArchiveSeo } from '../../../utils/archive';
import type { PostEntry } from '../../../utils/posts';

export async function getStaticPaths() {
  const { routePosts } = await getArchivePostsByRoute('shows-and-movies');
  return buildArchiveStaticPaths(routePosts, ARCHIVE_PAGE_SIZE);
}

const { currentPage, totalPages, posts } = Astro.props as {
  currentPage: number;
  totalPages: number;
  posts: PostEntry[];
};

const base = import.meta.env.BASE_URL;
const { allPosts } = await getArchivePostsByRoute('shows-and-movies');
const searchPosts = buildArchiveSearchItems(allPosts, base);
const siteOrigin = Astro.site?.toString() ?? 'http://127.0.0.1:4321';
const { seoTitle, seoDescription, canonicalUrl, ogImageUrl } = getArchiveSeo('shows-and-movies', currentPage, base, siteOrigin);
---
<ArchivePageDocument
  base={base}
  posts={posts}
  searchItems={searchPosts}
  currentPage={currentPage}
  totalPages={totalPages}
  majorRoute="shows-and-movies"
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  canonicalUrl={canonicalUrl}
  ogImageUrl={ogImageUrl}
/>
