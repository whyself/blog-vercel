---
import ArchivePageDocument from '../../../components/ArchivePageDocument.astro';
import { ARCHIVE_PAGE_SIZE, buildArchiveStaticPaths, getArchivePostsByRoute, getArchiveSeo } from '../../../utils/archive';
import { buildSearchItems, type PostEntry } from '../../../utils/posts';

export async function getStaticPaths() {
  const { routePosts } = await getArchivePostsByRoute('books');
  return buildArchiveStaticPaths(routePosts, ARCHIVE_PAGE_SIZE);
}

const { currentPage, totalPages, posts } = Astro.props as {
  currentPage: number;
  totalPages: number;
  posts: PostEntry[];
};

const base = import.meta.env.BASE_URL;
const { allPosts } = await getArchivePostsByRoute('books');
const searchPosts = buildSearchItems(allPosts, base);
const siteOrigin = Astro.site?.toString() ?? 'http://127.0.0.1:4321';
const { seoTitle, seoDescription, canonicalUrl, ogImageUrl } = getArchiveSeo('books', currentPage, base, siteOrigin);
---
<ArchivePageDocument
  base={base}
  posts={posts}
  searchItems={searchPosts}
  currentPage={currentPage}
  totalPages={totalPages}
  majorRoute="books"
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  canonicalUrl={canonicalUrl}
  ogImageUrl={ogImageUrl}
/>
